# Weekly Review Configuration
# Copy this file to .env and fill in your details

# GitHub Configuration
GITHUB_USERNAME=your-github-username

# Optional: Override default directories
# REVIEW_DIR=/custom/path/to/reports
# TEMPLATE_DIR=/custom/path/to/templates

# Optional: Calendar integration settings
# Set to "false" to disable calendar integration
ENABLE_CALENDAR=true

# Optional: Claude activity estimation
# Set to "false" to disable Claude session tracking
ENABLE_CLAUDE_TRACKING=true